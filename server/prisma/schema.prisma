generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model match_stats {
  id             Int     @id @default(autoincrement())
  match_id       Int
  player_id      Int
  goals          Int?    @default(0)
  assists        Int?    @default(0)
  yellow_cards   Int?    @default(0)
  minutes_played Int?    @default(0)
  matches        matches @relation(fields: [match_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players        players @relation(fields: [player_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([match_id, player_id])
  @@index([match_id], map: "idx_match_stats_match")
}

model matches {
  id                                Int           @id @default(autoincrement())
  tournament_id                     Int
  home_team_id                      Int
  away_team_id                      Int
  match_date                        DateTime      @db.Date
  home_score                        Int?          @default(0)
  away_score                        Int?          @default(0)
  referee_id                        Int?
  match_stats                       match_stats[]
  teams_matches_away_team_idToteams teams         @relation("matches_away_team_idToteams", fields: [away_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams_matches_home_team_idToteams teams         @relation("matches_home_team_idToteams", fields: [home_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referees                          referees?     @relation(fields: [referee_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournaments                       tournaments   @relation(fields: [tournament_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([match_date], map: "idx_matches_date")
  @@index([tournament_id], map: "idx_matches_tournament")
}

model players {
  id            Int            @id @default(autoincrement())
  first_name    String         @db.VarChar(100)
  last_name     String         @db.VarChar(100)
  position_id   Int
  salary        Decimal?       @db.Decimal(12, 2)
  born_year     Int?
  jersey_number Int?
  match_stats   match_stats[]
  positions     positions      @relation(fields: [position_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  team_players  team_players[]
  transfers     transfers[]
}

model positions {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  short_name String    @db.VarChar(10)
  players    players[]
}

model referees {
  id          Int       @id @default(autoincrement())
  first_name  String    @db.VarChar(100)
  last_name   String    @db.VarChar(100)
  nationality String?   @db.VarChar(100)
  matches     matches[]
}

model team_cities {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(100)
  teams teams[]
}

model team_players {
  id          Int       @id @default(autoincrement())
  team_id     Int
  player_id   Int
  joined_date DateTime? @db.Date
  left_date   DateTime? @db.Date
  is_captain  Boolean   @default(false)
  players     players   @relation(fields: [player_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams       teams     @relation(fields: [team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([player_id], map: "idx_team_players_player")
  @@index([team_id], map: "idx_team_players_team")
}

model teams {
  id                                      Int                @id @default(autoincrement())
  name                                    String             @db.VarChar(150)
  stadium                                 String?            @db.VarChar(150)
  founded_year                            Int?
  city_id                                 Int
  matches_matches_away_team_idToteams     matches[]          @relation("matches_away_team_idToteams")
  matches_matches_home_team_idToteams     matches[]          @relation("matches_home_team_idToteams")
  team_players                            team_players[]
  team_cities                             team_cities        @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournament_teams                        tournament_teams[]
  transfers_transfers_from_team_idToteams transfers[]        @relation("transfers_from_team_idToteams")
  transfers_transfers_to_team_idToteams   transfers[]        @relation("transfers_to_team_idToteams")
}

model tournament_countries {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  tournaments tournaments[]
}

model tournament_teams {
  id            Int         @id @default(autoincrement())
  tournament_id Int
  team_id       Int
  teams         teams       @relation(fields: [team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tournaments   tournaments @relation(fields: [tournament_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tournament_id, team_id])
}

model tournaments {
  id                   Int                  @id @default(autoincrement())
  name                 String               @db.VarChar(150)
  season               String               @db.VarChar(20)
  start_date           DateTime?            @db.Date
  end_date             DateTime?            @db.Date
  country_id           Int
  matches              matches[]
  tournament_teams     tournament_teams[]
  tournament_countries tournament_countries @relation(fields: [country_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transfer_types {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(100)
  transfers transfers[]
}

model transfers {
  id                                  Int            @id @default(autoincrement())
  player_id                           Int
  from_team_id                        Int
  to_team_id                          Int
  transfer_date                       DateTime       @db.Date
  fee                                 Decimal?       @default(0) @db.Decimal(14, 2)
  transfer_type_id                    Int
  teams_transfers_from_team_idToteams teams          @relation("transfers_from_team_idToteams", fields: [from_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  players                             players        @relation(fields: [player_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teams_transfers_to_team_idToteams   teams          @relation("transfers_to_team_idToteams", fields: [to_team_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transfer_types                      transfer_types @relation(fields: [transfer_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([player_id], map: "idx_transfers_player")
}
